#include <bits/stdc++.h>
 
using namespace std;
 
#define endl '\n' 
//#define int long long

const int maxn = 1000;
int vis[maxn][maxn];
int v[maxn][maxn];
int n, m;
vector<pair<int,int>> moves = {{1,0}, {-1,0}, {0,1}, {0,-1}};

bool verify(int i, int j){
    if(i >= 0 && i < n && j >= 0 && j < m && vis[i][j] == 0 && v[i][j] == '.'){
        return true;
    }
    else return false;
}

void dfs(int i, int j){
    vis[i][j] = 1;
    for(auto [x,y] : moves){
        if(verify(i+x, j+y)){
            dfs(i+x, j+y);
        }
    }
}

 
void solve () {
    cin >> n >> m;
    for(int i = 0; i < n; i++){
        for(int j = 0; j < m; j++){
            cin >> v[i][j];
        }
    }

    int res = 0;
    for(int i = 0; i < n; i++){
        for(int j = 0; j < m; j++){
            if(verify(i, j)){
                dfs(i, j);
                res++;
            }
        }
    }

    cout << res << endl;
}

signed main() {
    ios_base::sync_with_stdio(0);cin.tie(0);
    int TC = 0;
    if (TC){
        cin >> TC;
        while (TC--) solve();
    } else {
        solve();
    }
    return 0;
}